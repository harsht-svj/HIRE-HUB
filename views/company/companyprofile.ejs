<% layout('layouts/boilerplate') %>

<div class="row justify-content-center my-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4" style="border-radius:16px;">

            <!-- TOP -->
            <div class="text-center mb-4">
                <img src="<%= company.avatar || 'https://res.cloudinary.com/demo/image/upload/v1/samples/logo.png' %>"
                    style="width:100px; height:100px; border-radius:12px; object-fit:cover; border:2px solid #4f6ef7;">
                <h3 class="fw-bold mt-3 mb-1">Edit Company Profile</h3>
                <p class="text-muted">Update your company details</p>
            </div>

            <form action="/company/<%= company._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

                <!-- HIDDEN EXISTING AVATAR -->
                <input type="hidden" name="existingAvatar" value="<%= company.avatar %>">

                <!-- COMPANY NAME -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Company Name</label>
                    <div class="input-group">
                        <span class="input-group-text">🏢</span>
                        <input type="text" name="companyName" class="form-control"
                            value="<%= company.companyName %>" required>
                    </div>
                </div>

                <!-- AVATAR -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Company Logo</label>
                    <div class="input-group">
                        <span class="input-group-text">🖼️</span>
                        <input type="file" name="avatar" class="form-control" accept="image/*">
                    </div>
                    <div class="form-text">Leave empty to keep current logo</div>
                </div>

                <!-- CURRENT PASSWORD -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Current Password</label>
                    <div class="input-group">
                        <span class="input-group-text">🔒</span>
                        <input type="password" name="currentPassword" class="form-control"
                            placeholder="Enter current password">
                    </div>
                    <div class="form-text">Required only if changing password</div>
                </div>

                <!-- NEW PASSWORD -->
                <div class="mb-4">
                    <label class="form-label fw-bold">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text">🔑</span>
                        <input type="password" name="newPassword" class="form-control"
                            placeholder="Enter new password">
                    </div>
                    <div class="form-text">Leave empty to keep current password</div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-2">
                    <button type="submit" class="btn px-4 fw-bold"
                        style="background:#4f6ef7; color:#fff; border:none; border-radius:8px;">
                        Save Changes ✅
                    </button>
                    <a href="/company/dashboard" class="btn px-4"
                        style="background:transparent; color:rgba(255,255,255,0.6); border:1px solid rgba(255,255,255,0.15); border-radius:8px;">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>