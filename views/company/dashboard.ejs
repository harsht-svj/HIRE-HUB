<% layout('layouts/boilerplate') %>


<style>
    .table { background: #1c1c1e !important; }
    .table tbody tr { background: #1c1c1e !important; }
    .table tbody td { background: #1c1c1e !important; color: #fff !important; }
    .table thead th { background: #2c2c2e !important; color: rgba(255,255,255,0.7) !important; }
    .form-select {
        background: #2c2c2e !important;
        color: #fff !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
    }
    .form-select option { background: #2c2c2e; color: #fff; }
    .btn-outline-primary {
        border-color: rgba(255,255,255,0.2) !important;
        color: #fff !important;
    }
    .btn-outline-primary:hover { background: #4f6ef7 !important; }
    hr { border-color: rgba(255,255,255,0.06) !important; }
</style>

<!-- PROFILE HEADER -->
<div class="my-4 p-4" style="background:#1c1c1e; border:1px solid rgba(255,255,255,0.08); border-radius:16px;">
    <div class="d-flex justify-content-between align-items-center">
        
        <div class="d-flex align-items-center gap-4">
            <!-- AVATAR -->
            <img src="<%= currUser.avatar || 'https://res.cloudinary.com/demo/image/upload/v1/samples/people/smiling-man.jpg' %>" 
                style="width:170px; height:180px; border-radius:12px; object-fit:cover; border:2px solid #4f6ef7;">
            
            <!-- INFO -->
            <div>
                <h2 class="fw-bold mb-1"><%= currUser.companyName %></h2>
                <p style="color:#4f6ef7; font-size:14px; margin-bottom:8px;">🏢 Company</p>
                <br>
                <div class="d-flex gap-4">
                    <div>
                        <p style="color:rgba(255,255,255,0.4); font-size:12px; margin-bottom:2px;">Jobs Posted</p>
                        <p style="color:#fff; font-weight:600; margin:0;"><%= jobs.length %></p>
                    </div>
                    <div>
                        <p style="color:rgba(255,255,255,0.4); font-size:12px; margin-bottom:2px;">Total Applicants</p>
                        <p style="color:#fff; font-weight:600; margin:0;">
                            <%= jobs.reduce((acc, job) => acc + job.applications.length, 0) %>
                        </p>
                    </div>
                    <div>
                        <p style="color:rgba(255,255,255,0.4); font-size:12px; margin-bottom:2px;">Email</p>
                        <p style="color:#fff; font-weight:600; margin:0; font-size:13px;"><%= currUser.email %></p>
                    </div>
                    <% if(currUser.companyWebsite) { %>
                    <div>
                        <p style="color:rgba(255,255,255,0.4); font-size:12px; margin-bottom:2px;">Website</p>
                        <a href="<%= currUser.companyWebsite %>" target="_blank"
                            style="color:#7aa4f7; font-size:13px; text-decoration:none;">
                            Visit →
                        </a>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- TOP RIGHT BUTTONS -->
      <!-- TOP RIGHT BUTTONS -->
<div class="d-flex flex-column gap-2 align-items-end" style="align-self: flex-start;">
    <a href="/company/<%= currUser._id %>/edit"
        style="background:#1a2a4a; color:#7aa4f7; border:1px solid #7aa4f7; border-radius:8px; padding:8px 13px; font-size:15px; text-decoration:none; white-space:nowrap; width:160px; text-align:center;">
        ✏️ Edit Profile
    </a>
    <Br><br><br>
    <a href="/jobs/new" class="btn px-4 py-2"
        style="background:#4f6ef7; color:#fff; border:none; border-radius:8px; width:160px; text-align:center;">
        + Post New Job
    </a>
</div>

    </div>
</div>

<% if(jobs.length === 0) { %>
    <div class="text-center py-5">
        <h4 class="text-muted">You haven't posted any jobs yet</h4>
        <a href="/jobs/new" class="btn btn-primary mt-3">Post Your First Job</a>
    </div>
<% } else { %>
    <% for(let job of jobs) { %>
        <div class="job-card mb-4">
           <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="fw-bold mb-1"><%= job.title %></h5>
        <p class="text-muted mb-0">📍 <%= job.location %> &nbsp;|&nbsp; <%= job.jobType %></p>
    </div>

    <div class="d-flex align-items-center gap-2">

        <span class="badge bg-primary rounded-pill">
            <%= job.applications.length %> Applicants
        </span>

    <!-- EDIT BUTTON -->
<a href="/jobs/<%= job._id %>/edit" class="btn btn-sm px-3"
    style="background:#4f6ef7; color:#fff; border:none; border-radius:8px;">
    ✏️ Edit
</a>

<!-- DELETE BUTTON -->
<form action="/jobs/<%= job._id %>?_method=DELETE" method="POST"
    onsubmit="return confirm('Are you sure you want to delete this job?')"
    style="margin: 0;">
    <button type="submit" class="btn btn-sm px-3"
        style="background:#2a0f0f; color:#f09595; border:1px solid #f09595; border-radius:8px;">
        🗑️ Delete
    </button>
</form>

    </div>
</div>
           

            <% if(job.applications.length === 0) { %>
                <p class="text-muted">No applicants yet.</p>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Skills</th>
                                <th>View Applicant</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for(let app of job.applications) { %>
                                <tr>
                                  
<td class="fw-bold">
    <%= app.applicant.name %>
</td>
<td class="text-muted"><%= app.applicant.email %></td>
<td>
    <% if(app.applicant.skills && app.applicant.skills.length > 0) { %>
        <%= app.applicant.skills.join(', ') %>
    <% } else { %>
        <span class="text-muted">—</span>
    <% } %>
</td>
<td>
    <!-- VIEW PROFILE LINK -->
    <a href="/applicant/<%= app.applicant._id %>/profile"
        style="color:#7aa4f7; font-size:13px; text-decoration:none;">
        View Profile →
    </a>
</td>
<td>
    <span class="badge-status-<%= app.status %>">
        <%= app.status %>
    </span>
</td>

<td>
    <form action="/jobs/<%= job._id %>/applications/<%= app.applicant._id %>/status" method="POST" class="d-flex gap-2">
        <select name="status" class="form-select form-select-sm" style="width: auto;">
            <option value="pending"  <%= app.status === 'pending'  ? 'selected' : '' %>>Pending</option>
            <option value="accepted" <%= app.status === 'accepted' ? 'selected' : '' %>>Accepted</option>
            <option value="rejected" <%= app.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
        </select>
        <button type="submit" class="btn btn-sm"
            style="background:#1a2a4a; color:#7aa4f7; border:1px solid #7aa4f7; border-radius:8px;">
            Update
        </button>
    </form>
</td>

                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
        <hr>
    <% } %>
<% } %>