<% layout('layouts/boilerplate') %>

<div class="row justify-content-center my-5">
    <div class="col-md-6 text-center">
        <div style="background:#1c1c1e; border:1px solid rgba(255,255,255,0.08); 
            border-radius:16px; padding:48px 32px;">

            <!-- ERROR CODE -->
            <h1 style="font-size:5rem; font-weight:700; color:#4f6ef7; margin-bottom:0;">
                <%= statusCode %>
            </h1>

            <!-- MESSAGE -->
            <h3 class="fw-bold mt-2 mb-2"><%= message %></h3>
            <p style="color:rgba(255,255,255,0.45);" class="mb-4">
                <%= description %>
            </p>

            <!-- BUTTONS -->
            <div class="d-flex gap-3 justify-content-center">
                <a href="/" class="btn px-4 py-2"
                    style="background:#4f6ef7; color:#fff; border:none; border-radius:8px;">
                    Go Home
                </a>
                <a href="/jobs" class="btn px-4 py-2"
                    style="background:transparent; color:rgba(255,255,255,0.6); 
                    border:1px solid white; border-radius:8px;">
                    Browse Jobs
                </a>
            </div>

        </div>
    </div>
</div>